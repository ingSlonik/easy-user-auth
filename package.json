{
  "name": "easy-user-auth",
  "version": "1.0.0",
  "description": "Generic authentication, registration and password recovery library.",
  "main": "dist/server.js",
  "browser": "dist/client.js",
  "types": "dist/types.d.ts",
  "scripts": {
    "build": "tsc"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.9",
    "valibot": "^1.1.0"
  },
  "peerDependencies": {
    "express": "*",
    "react": "*",
    "react-dom": "*"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
