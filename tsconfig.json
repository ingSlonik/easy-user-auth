{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "declaration": true,
    "outDir": "./"
  },
  "include": [
    "src/server.ts",
    "src/client.ts",
    "src/react.tsx",
    "src/types.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
