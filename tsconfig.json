{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "declaration": true,
    "outDir": "./dist"
  },
  "include": [
    "server.ts",
    "client.ts",
    "react.tsx",
    "types.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
